# DashScope (Qwen) API key for LLM and embeddings
DASHSCOPE_API_KEY="your_dashscope_api_key"

# AMap Web Service API key for IP location and weather
AMAP_WEB_SERVICE_KEY="your_amap_web_service_key"

# Optional runtime overrides
ZST_USER_ID=1001
ZST_USER_LOCATION=南京

# Optional enterprise backend
ZST_BACKEND_URL=http://localhost:8000
DATABASE_URL=sqlite:///./data/zst_enterprise.db
REDIS_URL=redis://localhost:6379/0
API_RATE_LIMIT_PER_MINUTE=60
